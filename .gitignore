# ============================================
# Telecom Test Toolkit — .gitignore
# ============================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---------- Distribution / Packaging ----------
dist/
build/
*.egg-info/
*.egg
*.whl
sdist/
wheels/
pip-wheel-metadata/

# ---------- Virtual Environments ----------
.env/
.venv/
env/
venv/
ENV/

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ---------- OS ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---------- Testing ----------
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml

# ---------- TTT Ecosystem ----------
# Pipeline output (generated at runtime)
ttt_output/
ttt_data.json
*.html

# ---------- Logs ----------
*.log
logs/

# ---------- Jupyter ----------
.ipynb_checkpoints/

# ---------- Streamlit ----------
.streamlit/

# ---------- Node (if dashboard uses npm) ----------
node_modules/
